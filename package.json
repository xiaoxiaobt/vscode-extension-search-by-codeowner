{
  "name": "search-by-code-owner",
  "displayName": "Search by Code Owner",
  "description": "Search files by code ownership using CODEOWNERS file from GitHub, GitLab, Gitea, and Bitbucket",
  "publisher": "TaigeWang",
  "icon": "media/logo.png",
  "version": "0.1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaoxiaobt/vscode-extension-search-by-codeowner"
  },
  "homepage": "https://github.com/xiaoxiaobt/vscode-extension-search-by-codeowner/blob/main/README.md",
  "bugs": {
    "url": "https://github.com/xiaoxiaobt/vscode-extension-search-by-codeowner/issues",
    "email": "xiaoxiaobt@gmail.com"
  },
  "keywords": [
    "vscode",
    "search",
    "codeowners"
  ],
  "engines": {
    "vscode": "^1.103.0",
    "node": ">=24.12.0",
    "pnpm": ">=10.20.0"
  },
  "categories": [
    "Other"
  ],
  "pricing": "Free",
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "search-by-code-owner",
          "title": "Search by Code Owner",
          "icon": "media/logo.svg"
        }
      ]
    },
    "views": {
      "search-by-code-owner": [
        {
          "id": "codeOwner.searchView",
          "name": "",
          "type": "webview",
          "when": "true",
          "icon": "media/logo.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "codeOwner.refresh",
        "title": "Refresh",
        "category": "Search by Code Owner",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codeOwner.refresh",
          "when": "view == codeOwner.searchView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src --ext ts",
    "package": "rm -rf out && vsce package",
    "publish": "vsce publish",
    "dev": "code --extensionDevelopmentPath=$(pwd)"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.13",
    "@types/vscode": "^1.103.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "knip": "^5.83.1"
  }
}
